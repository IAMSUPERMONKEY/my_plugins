{
  "module": {
    "name": "manage_calendar_events",
    "type": "har",
    "deviceTypes": [
      "default",
      "tablet"
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.READ_CALENDAR",
        "reason": "$string:calendar_read_permission_reason",
        "usedScene": {
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.WRITE_CALENDAR",
        "reason": "$string:calendar_write_permission_reason",
        "usedScene": {
          "when": "always"
        }
      }
    ]
  }
}
